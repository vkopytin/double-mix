<resources>
    <layout id="main">
        <drawable id="background" />

        <drawable id="analogClock" class="AnalogClockView">
            <param name="locX">130</param>
            <param name="locY">130</param>
            <param name="hourHandResId">@Drawables.HourHand</param>
            <param name="minuteHandResId">@Drawables.MinuteHand</param>
        </drawable>

        <label id="currentTime" visible="true" x="128" y="146" text="10:10" color="#000000" font="Graphics.FONT_LARGE" justification="Graphics.TEXT_JUSTIFY_CENTER" />
        <label id="weekDay" visible="true" x="190" y="116" text="MON" color="#000000" font="Graphics.FONT_TINY" justification="Graphics.TEXT_JUSTIFY_LEFT" />
        <label id="monthAndDate" visible="true" x="154" y="68" text="JAN 01" color="#000000" font="Graphics.FONT_TINY" justification="Graphics.TEXT_JUSTIFY_LEFT" />
        <label id="stepsCount" visible="true" x="130" y="224" text="12345" color="#000000" font="Graphics.FONT_GLANCE" justification="Graphics.TEXT_JUSTIFY_CENTER" />
        <label id="heartRate" visible="true" x="38" y="126" text="75" color="#000000" font="Graphics.FONT_TINY" justification="Graphics.TEXT_JUSTIFY_CENTER" />
        <label id="energyLevel" visible="true" x="82" y="214" text="80%" color="#000000" font="Graphics.FONT_GLANCE" justification="Graphics.TEXT_JUSTIFY_CENTER" />
        <label id="barometer" visible="true" x="184" y="214" text="1013" color="#000000" font="Graphics.FONT_GLANCE" justification="Graphics.TEXT_JUSTIFY_CENTER" />

        <drawable id="secondsClock" class="SecondsClockView">
            <param name="locX">130</param>
            <param name="locY">130</param>
            <param name="rezId">@Drawables.SecondsHand</param>
        </drawable>

        <drawable id="infoWeather" class="InfoWeather">
            <param name="locX">80</param>
            <param name="locY">40</param>
            <param name="width">40</param>
            <param name="color">Graphics.COLOR_BLACK</param>
        </drawable>
    </layout>

</resources>