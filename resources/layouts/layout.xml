<resources>
    <layout id="main">
        <drawable id="background" />

        <drawable id="analogClock" class="AnalogClockView">
            <param name="locX">130</param>
            <param name="locY">130</param>
            <param name="hourHandResId">@Drawables.HourHand</param>
            <param name="minuteHandResId">@Drawables.MinuteHand</param>
        </drawable>

        <label id="currentTime" visible="true" x="80" y="150" text="10:10" color="Graphics.COLOR_DK_GRAY" font="Graphics.FONT_NUMBER_MILD" justification="Graphics.TEXT_JUSTIFY_LEFT" />
        <label id="weekDay" visible="true" x="170" y="110" text="MON" color="Graphics.COLOR_DK_GRAY" font="Graphics.FONT_TINY" justification="Graphics.TEXT_JUSTIFY_LEFT" />
        <label id="monthAndDate" visible="true" x="40" y="110" text="JAN 01" color="Graphics.COLOR_DK_GRAY" font="Graphics.FONT_TINY" justification="Graphics.TEXT_JUSTIFY_LEFT" />
        <label id="stepsCount" visible="true" x="100" y="70" text="12345" color="Graphics.COLOR_DK_GRAY" font="Graphics.FONT_SMALL" justification="Graphics.TEXT_JUSTIFY_LEFT" />

        <drawable id="secondsClock" class="SecondsClockView">
            <param name="locX">130</param>
            <param name="locY">130</param>
            <param name="rezId">@Drawables.SecondsHand</param>
        </drawable>

        <drawable id="infoWeather" class="InfoWeather">
            <param name="locX">100</param>
            <param name="locY">24</param>
            <param name="width">40</param>
            <param name="color">Graphics.COLOR_DK_GRAY</param>
        </drawable>
    </layout>

</resources>